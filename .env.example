# GEMINI_API_KEY: Required for Gemini AI API calls
# Generate from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Server-side Encryption
# Generate a random 32-byte hex string: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=your_32byte_hex_string_here

# JWT Secret for session tokens
# Generate: openssl rand -base64 64
JWT_SECRET=your_base64_jwt_secret_here

# Deployment
# Set to 'production' on Render
NODE_ENV=development
PORT=3000

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "server.ts",
    "server/**/*.ts",
    "server/**/*.mts",
    "server/**/*.cts"
  ],
  "exclude": [
    "node_modules",
    "src",
    "dist"
  ]
}
